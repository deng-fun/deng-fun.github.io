---
import { SeriesNavigation } from '@components/post/SeriesNavigation';
import { SeriesPostList } from '@components/post/SeriesPostList';
import HomeSiderSegmented from '@components/ui/segmented/HomeSiderSegmented';
import { HomeSiderSegmentType, HomeSiderType } from '@constants/enum';
import { getAdjacentSeriesPosts, getSeriesPosts } from '@lib/content/posts';
import { toPostRef, toPostRefs } from '@lib/content/transforms';
import { cn } from '@lib/utils';
import type { BlogPost } from 'types/blog';
import HomeInfo from './HomeInfo.astro';
import { ScrollProgress } from './ScrollProgress';
import { TableOfContents } from './TableOfContents/index';

interface Props {
  type?: HomeSiderType;
  className?: string;
  isDrawer?: boolean;
  post?: BlogPost;
}

const { type = HomeSiderType.HOME, className, isDrawer = false, post } = Astro.props;
const defaultSegmentType = type === HomeSiderType.POST ? HomeSiderSegmentType.DIRECTORY : HomeSiderSegmentType.INFO;

// 获取系列文章（转换为轻量级引用）
const seriesPosts = post && type === HomeSiderType.POST ? toPostRefs(await getSeriesPosts(post)) : [];

// 获取上一篇和下一篇（转换为轻量级引用）
const adjacentPosts =
  post && type === HomeSiderType.POST ? await getAdjacentSeriesPosts(post) : { prevPost: null, nextPost: null };
const prevPost = adjacentPosts.prevPost ? toPostRef(adjacentPosts.prevPost) : null;
const nextPost = adjacentPosts.nextPost ? toPostRef(adjacentPosts.nextPost) : null;
---

<div
  class={cn(
    'page-home-sider shadow-home-sider sticky top-0 tablet:overscroll-none self-start flex min-w-64 max-w-64 flex-col items-stretch tablet:hidden overflow-auto h-screen px-2 scroll-gutter-stable',
    className,
  )}
  transition:name={isDrawer ? 'page-home-sider-drawer' : 'page-home-sider'}
>
  {
    type === HomeSiderType.POST && (
      <HomeSiderSegmented
        client:only="react"
        className="my-4 tablet:mb-0 flex justify-between text-sm/6 w-auto"
        itemClass="grow"
        defaultValue={defaultSegmentType}
        id="inner-home-sider"
      />
    )
  }

  <div
    id="sider-content-container"
    class="vertical-scrollbar flex-1 overflow-x-hidden overflow-y-auto md:pt-2 md:pl-3 tablet:-mx-2 relative"
    data-type={type}
    data-default-type={defaultSegmentType}
  >
    <div id="sider-slot-info" class="sider-slot" data-slot-type="info">
      <HomeInfo className={type === HomeSiderType.HOME ? 'pt-18 md:pt-0' : ''} />
    </div>
    <div id="sider-slot-directory" class="sider-slot overflow-hidden h-full hidden" data-slot-type="directory">
      {type === HomeSiderType.POST && <TableOfContents client:only="react" enableNumbering={post?.data.tocNumbering ?? true} />}
    </div>
    <div id="sider-slot-series" class="sider-slot hidden" data-slot-type="series">
      {type === HomeSiderType.POST && <SeriesPostList client:load posts={seriesPosts} currentPostSlug={post?.slug} />}
    </div>
  </div>

  <!-- 内联脚本：在 DOM 解析后立即隐藏不需要的内容，避免闪烁 -->
  <script is:inline data-astro-rerun>
    (function () {
      const container = document.getElementById('sider-content-container');
      if (!container) return;

      const defaultType = container.getAttribute('data-default-type') || 'info';
      const pageType = container.getAttribute('data-type');
      
      // 获取所有 slot
      const slots = {
        info: document.getElementById('sider-slot-info'),
        directory: document.getElementById('sider-slot-directory'),
        series: document.getElementById('sider-slot-series')
      };
      
      // 先隐藏所有
      Object.values(slots).forEach(function(slot) {
        if (slot) slot.classList.add('hidden');
      });
      
      // 显示默认的
      const defaultSlot = slots[defaultType] || slots.info;
      if (defaultSlot) defaultSlot.classList.remove('hidden');
    })();
  </script>

  {
    type === HomeSiderType.POST && (
      <SeriesNavigation client:load prevPost={prevPost} nextPost={nextPost} className="w-full px-2" />
    )
  }

  <ScrollProgress client:only="react" className="mt-auto w-full rounded-full pt-4" />
</div>

<script>
  // 定义常量
  var HomeSiderSegmentType = {
    INFO: 'info',
    DIRECTORY: 'directory',
    SERIES: 'series'
  };

  // 获取所有 slot 元素
  function getSlots() {
    return {
      info: document.getElementById('sider-slot-info'),
      directory: document.getElementById('sider-slot-directory'),
      series: document.getElementById('sider-slot-series')
    };
  }

  // 显示指定的内容
  function showContent(type, skipAnimation) {
    var slots = getSlots();
    var targetSlot = slots[type] || slots.info;
    
    if (!targetSlot) return;

    // 如果是初始化或者跳过动画，直接切换
    if (skipAnimation) {
      // 先隐藏所有
      Object.values(slots).forEach(function(slot) {
        if (slot) slot.classList.add('hidden');
      });
      // 再显示目标
      targetSlot.classList.remove('hidden');
      return;
    }

    // 如果已经在显示目标内容，直接返回
    if (!targetSlot.classList.contains('hidden')) {
      return;
    }

    // 隐藏其他内容（添加退出动画）
    Object.keys(slots).forEach(function(key) {
      var slot = slots[key];
      if (slot && slot !== targetSlot && !slot.classList.contains('hidden')) {
        slot.classList.add('exiting');
        setTimeout(function() {
          slot.classList.add('hidden');
          slot.classList.remove('exiting');
        }, 200);
      }
    });

    // 显示目标内容（添加进入动画）
    targetSlot.classList.remove('hidden');
    requestAnimationFrame(function() {
      targetSlot.classList.add('entering');
      setTimeout(function() {
        targetSlot.classList.remove('entering');
      }, 200);
    });
  }

  // 监听 store 变化
  function initStoreListener() {
    var container = document.getElementById('sider-content-container');
    if (!container) return;
    
    var pageType = container.getAttribute('data-type');
    var defaultType = container.getAttribute('data-default-type') || 'info';
    
    // 如果是首页，不需要监听
    if (pageType === 'home') return;

    var lastValue = null;
    
    // 尝试从全局获取 store
    function checkStore() {
      if (window.__homeSiderSegmentType) {
        var store = window.__homeSiderSegmentType;
        
        // 立即获取当前值并同步
        var currentValue = store.get ? store.get() : null;
        
        // 如果当前值和默认值不一致，先设置默认值
        if (currentValue !== defaultType) {
          store.set(defaultType);
          currentValue = defaultType;
        }
        
        if (currentValue && currentValue !== lastValue) {
          lastValue = currentValue;
          showContent(currentValue, true);
        }
        
        // 订阅变化
        if (store.listen) {
          store.listen(function(value) {
            if (value !== lastValue) {
              lastValue = value;
              showContent(value, false);
            }
          });
        }
        
        return true;
      }
      return false;
    }

    // 先尝试立即检查
    if (checkStore()) return;

    // 如果没有，轮询等待 store 出现
    var maxAttempts = 100; // 最多等待10秒
    var attempts = 0;
    
    var pollInterval = setInterval(function() {
      attempts++;
      if (checkStore() || attempts >= maxAttempts) {
        clearInterval(pollInterval);
      }
    }, 100);
  }

  // 初始化
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initStoreListener);
  } else {
    initStoreListener();
  }

  // 支持 Astro 的视图过渡
  document.addEventListener('astro:page-load', initStoreListener);
</script>

<style>
  /* 圣诞模式下调整 z-index，让装饰效果正确显示 */
  :global(html.christmas) .page-home-sider {
    z-index: 5;
  }

  sider-content {
    position: relative;
  }

  .sider-slot {
    position: absolute;
    top: auto;
    left: 0;
    right: 0;
  }

  @media (768px >= width) {
    .sider-slot {
      position: relative;
    }
  }

  .sider-slot.hidden {
    display: none;
  }

  /* 默认无动画，适用于 prefers-reduced-motion: reduce */
  .sider-slot.entering,
  .sider-slot.exiting {
    animation: none;
  }

  /* 只在用户未设置 reduce-motion 时应用动画 */
  @media (prefers-reduced-motion: no-preference) {
    @keyframes slide-in-from-right {
      from {
        opacity: 0;
        transform: translateX(12px);
      }
      to {
        opacity: 1;
        transform: translateX(0);
      }
    }

    @keyframes slide-out-to-left {
      from {
        opacity: 1;
        transform: translateX(0);
      }
      to {
        opacity: 0;
        transform: translateX(-12px);
      }
    }

    .sider-slot.entering {
      animation: slide-in-from-right 0.2s ease-in-out;
    }

    .sider-slot.exiting {
      animation: slide-out-to-left 0.2s ease-in-out;
    }
  }
</style>
